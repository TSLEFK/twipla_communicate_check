{
  "manifest_version": 3,
  "name": "Twitter Community Checker",
  "version": "1.0",
  "description": "TwiplaでTwitterコミュニティに参加しているかを確認できます",
  "permissions": [
    "storage",
    "cookies",
    "webRequest"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twipla.jp/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twipla.jp/*"],
      "js": ["storage.js", "communityApi.js", "content.js"]
    }
  ]
}